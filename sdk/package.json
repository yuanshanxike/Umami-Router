{
  "name": "@umami_router/sdk",
  "version": "0.1.0",
  "description": "Umami analytics SDK with Vue and Next.js integrations",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./nextjs": {
      "import": "./dist/nextjs/index.mjs",
      "require": "./dist/nextjs/index.js",
      "types": "./dist/nextjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build:bun",
    "build:node": "tsup",
    "build:bun": "bunx tsup",
    "dev": "bun run dev:bun",
    "dev:node": "tsup --watch",
    "dev:bun": "bunx tsup --watch",
    "typecheck": "bun run typecheck:bun",
    "typecheck:node": "tsc --noEmit",
    "typecheck:bun": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0"
  },
  "packageManager": "bun@1.3.9"
}
